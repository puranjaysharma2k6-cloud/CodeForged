generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
 enum Verdict {
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  COMPILATION_ERROR
  RUNTIME_ERROR
}
enum ContestStatus {
  UPCOMING
  ONGOING
  PAST
}
enum Mode {
  OFFICIAL
  VIRTUAL
}
model User { 
  id String @id @default(uuid()) 
  email        String  @unique
  username     String  @unique
  passwordHash String
  name         String?
  currentRating Int @default(0)
  submission   Submission[]
  contest      ContestRegistration[]
  ratingHistory      ContestResult[]
  avatarUrl    String?
  @@index([id])
  @@index([currentRating(sort: Desc)])
}   


model Problem { 
  id String @id @default(uuid())
  title     String
  content   String?
  published Boolean @default(false) 
  submission Submission[]
  contest   Contest @relation(fields: [contestId], references: [id])
  contestId String 
   
} 
//one to many mapping for problems one problem belongs to a signle contest
//many to many for registrations
//many to many for results

model Contest{
  id String @id @default(uuid())
  title String
  startTime DateTime
  duration Int
  editorial String?
   status    ContestStatus @default(UPCOMING)
  problems Problem[] 
  participants ContestRegistration[]
  results ContestResult[]

  @@index([id])
}

model Submission {
  id         String   @id @default(uuid()) 
  code       String   @db.Text             
  language   String                        
  status     Verdict                       
  runtime    Int?                          
  memory     Int?                          
  createdAt  DateTime @default(now())      

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  problemId  String

  @@index([userId, status, problemId])
}

model ContestRegistration {
  userId       String
  contestId    String
  registeredAt DateTime @default(now())
   mode          Mode
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest      Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  
  @@id([userId, contestId]) 
}

model ContestResult {
  id            String   @id @default(uuid())
  title         String
  userId        String
  contestId     String
  mode          Mode
  score         Int      @default(0)
  penalty       Int      @default(0) 
  newRating     Int      
  // 2. The Historical Snapshot (Crucial!)
  finalRank     Int?     
  
  //  Problem Breakdown (The grid of green checks and red crosses)
  problemStats  Json?    

  user          User     @relation(fields: [userId], references: [id])
  contest       Contest  @relation(fields: [contestId], references: [id])

  
  @@unique([userId, contestId]) 
  
  //these indexes fetch leaderboardquickly
  // mode field is important virtual participants need to be filtered out
  // if overall rank need to be checked ( virtual + official) seperately query and sum users gt than me
  //@@index([contestId,mode,score(sort: Desc), penalty(sort: Asc)]) 
}